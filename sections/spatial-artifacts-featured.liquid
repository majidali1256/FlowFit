<section class="py-20 px-6 md:px-16 bg-[#f5f3f6]/60 border-y border-[#031635]/5">
  <div class="max-w-[1280px] mx-auto">
    <div class="text-center mb-12">
      <span class="text-xs font-semibold tracking-widest uppercase text-[#70585b] block mb-2">{{ section.settings.subheading }}</span>
      <h2 class="font-headline-md text-3xl md:text-4xl font-bold text-[#031635]">{{ section.settings.heading }}</h2>
    </div>

    {% assign featured_prod = all_products[section.settings.featured_product] %}

    <div class="grid grid-cols-1 md:grid-cols-12 gap-8 items-center">
      <div class="md:col-span-7">
        <div class="glass-panel p-8 md:p-12 rounded-3xl soft-shadow relative overflow-hidden group">
          <div class="absolute top-6 right-6 z-10">
            <span class="bg-[#fbdbde] text-[#031635] px-4 py-1.5 rounded-full text-xs font-semibold uppercase tracking-wider">Limited Edition</span>
          </div>
          {% if featured_prod.featured_image %}
            <img src="{{ featured_prod.featured_image | img_url: '800x' }}" alt="{{ featured_prod.title }}" class="w-full h-[360px] object-contain mix-blend-multiply transform group-hover:scale-105 transition-transform duration-700 ease-out" />
          {% else %}
            <img src="https://lh3.googleusercontent.com/aida/AP1WRLvKZ5LDIRYOddqxqKBSi5T3dK2VVK8SFnBB6R4rmAsZeXAvfdw5Znd8cEJQpu_Nf8CI23V6qUNkIQGwQ0r5bTfI_6ZhmpxHF4L1kbDpwVKZZ0XXS8JrDAaO6f86ZHojw-p3UvYiIJg2cu8-15YEsf_WJgyGyXqQshPe5ysOpuef_WUuY9uWdgFk6prsI8wXbdhwG1P-1oJU9mC4UPq6-I7sU4bJ5MP78g6yrihWMVzPjt41Jt3sadD21wU" alt="Aurum Wave Bag" class="w-full h-[360px] object-contain mix-blend-multiply transform group-hover:scale-105 transition-transform duration-700 ease-out" />
          {% endif %}
        </div>
      </div>

      <div class="md:col-span-5 space-y-6 md:pl-6">
        <div class="space-y-2">
          <span class="text-xs text-[#44474e] uppercase tracking-widest">Masterpiece Collection</span>
          <h3 class="font-headline-md text-3xl md:text-4xl font-bold text-[#031635]">
            {{ featured_prod.title | default: 'The Aurum Wave Bag' }}
          </h3>
          <p class="text-2xl font-semibold text-[#031635]">
            {{ featured_prod.price | default: 125000 | money }}
          </p>
        </div>
        <p class="text-[#44474e] leading-relaxed">
          {{ featured_prod.description | strip_html | truncatewords: 35 | default: 'A study in contradiction. Merging architectural precision with fluid movement, the Aurum Wave Bag is crafted from memory-tensioned titanium and adaptive micro-suede.' }}
        </p>
        <div class="pt-4 flex flex-col sm:flex-row gap-4">
          {% if featured_prod %}
            <form action="/cart/add" method="post" class="flex-1">
              <input type="hidden" name="id" value="{{ featured_prod.selected_or_first_available_variant.id }}" />
              <button type="submit" class="w-full bg-[#031635] text-white text-sm font-semibold tracking-wider uppercase px-8 py-4 rounded-lg btn-hover-lift">
                Add to Bag — {{ featured_prod.price | money }}
              </button>
            </form>
          {% else %}
            <button class="bg-[#031635] text-white text-sm font-semibold tracking-wider uppercase px-8 py-4 rounded-lg btn-hover-lift flex-1">
              Add to Bag — $1,250
            </button>
          {% endif %}
          <a href="{{ featured_prod.url | default: '/products/aurum-wave-bag' }}" class="bg-[#fbdbde] text-[#031635] text-sm font-semibold tracking-wider uppercase px-6 py-4 rounded-lg btn-hover-lift text-center">
            View Details
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Spatial Artifact",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Featured Artifact"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Spatial Artifacts"
    },
    {
      "type": "product",
      "id": "featured_product",
      "label": "Select Featured Product"
    }
  ],
  "presets": [
    {
      "name": "Featured Spatial Artifact"
    }
  ]
}
{% endschema %}
