<div class="max-w-[1280px] mx-auto px-6 md:px-16 pt-8 pb-20 grid grid-cols-1 lg:grid-cols-12 gap-12">
  <!-- Left Column: Media & 3D Viewer -->
  <div class="lg:col-span-7 flex flex-col gap-6">
    <div class="w-full aspect-[4/3] md:aspect-[16/10] bg-white rounded-3xl overflow-hidden relative shadow-sm border border-[#031635]/5 flex items-center justify-center p-8">
      {% if product.featured_image %}
        <img src="{{ product.featured_image | img_url: '1000x' }}" alt="{{ product.title }}" class="max-h-[380px] w-auto object-contain mix-blend-multiply" />
      {% else %}
        <img src="https://lh3.googleusercontent.com/aida/AP1WRLvKZ5LDIRYOddqxqKBSi5T3dK2VVK8SFnBB6R4rmAsZeXAvfdw5Znd8cEJQpu_Nf8CI23V6qUNkIQGwQ0r5bTfI_6ZhmpxHF4L1kbDpwVKZZ0XXS8JrDAaO6f86ZHojw-p3UvYiIJg2cu8-15YEsf_WJgyGyXqQshPe5ysOpuef_WUuY9uWdgFk6prsI8wXbdhwG1P-1oJU9mC4UPq6-I7sU4bJ5MP78g6yrihWMVzPjt41Jt3sadD21wU" alt="Aurum Wave Bag" class="max-h-[380px] w-auto object-contain mix-blend-multiply" />
      {% endif %}
    </div>

  </div>

  <!-- Right Column: Product Detail Form -->
  <div class="lg:col-span-5">
    <div class="glass-panel rounded-3xl p-8 shadow-sm sticky top-32 flex flex-col gap-8">
      <div>
        <h1 class="font-headline-md text-4xl md:text-5xl font-bold text-[#031635]">{{ product.title | default: 'Aurum & Onda' }}</h1>
        <p class="text-2xl font-bold text-[#031635] mt-2">{{ product.price | default: 125000 | money }}</p>
      </div>

      <div class="text-[#44474e] leading-relaxed">
        {{ product.description | default: 'A masterclass in spatial form and material science. Merging aerospace-grade titanium alloy frames with ultra-soft, responsive memory-suede for an adaptive silhouette.' }}
      </div>

      <form action="/cart/add" method="post" enctype="multipart/form-data" class="space-y-6">
        {% if product.variants.size > 1 %}
          <div class="space-y-2">
            <label class="text-xs font-semibold text-[#031635] uppercase tracking-widest">Select Variant</label>
            <select name="id" class="w-full rounded-xl border-gray-300 py-3 text-sm font-semibold">
              {% for variant in product.variants %}
                <option value="{{ variant.id }}">{{ variant.title }} - {{ variant.price | money }}</option>
              {% endfor %}
            </select>
          </div>
        {% else %}
          <input type="hidden" name="id" value="{{ product.variants.first.id }}" />
        {% endif %}

        <button type="submit" class="w-full bg-[#031635] text-white font-semibold text-sm py-4 rounded-xl btn-hover-lift uppercase tracking-widest flex items-center justify-center gap-3">
          Add to Bag — {{ product.price | default: 125000 | money }}
          <span class="material-symbols-outlined text-lg">arrow_forward</span>
        </button>
      </form>

      <!-- Spatial Specs Bento Grid -->
      <div class="flex flex-col gap-4 pt-4 border-t border-[#031635]/10">
        <h3 class="font-headline-md text-xl font-bold text-[#031635]">Spatial Specs</h3>
        <div class="grid grid-cols-2 gap-4">
          <div class="bg-white p-4 rounded-2xl border border-[#031635]/5 flex flex-col gap-1">
            <span class="material-symbols-outlined text-[#031635] text-xl">architecture</span>
            <span class="text-xs font-semibold text-[#031635] uppercase tracking-wider mt-1">Architecture</span>
            <span class="text-sm text-[#44474e]">Tensioned Titanium</span>
          </div>
          <div class="bg-white p-4 rounded-2xl border border-[#031635]/5 flex flex-col gap-1">
            <span class="material-symbols-outlined text-[#031635] text-xl">texture</span>
            <span class="text-xs font-semibold text-[#031635] uppercase tracking-wider mt-1">Textile</span>
            <span class="text-sm text-[#44474e]">Adaptive Micro-Suede</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Product Details",
  "settings": []
}
{% endschema %}
