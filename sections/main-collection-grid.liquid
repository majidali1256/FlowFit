<div class="max-w-[1280px] mx-auto px-6 md:px-16 pt-8 pb-20">
  <header class="mb-12 flex flex-col md:flex-row justify-between items-start md:items-end gap-6">
    <div>
      <h1 class="font-headline-md text-4xl md:text-6xl text-[#031635] font-bold mb-3">{{ collection.title | default: 'Spatial Collection 04' }}</h1>
      <p class="text-lg text-[#44474e]">{{ collection.description | default: 'Designed for fluidity, movement, and architectural balance. Engineered with tensioned titanium and responsive memory textiles.' }}</p>
    </div>
    <div class="flex flex-wrap gap-2">
      <span class="px-4 py-2 rounded-full bg-[#031635] text-white text-xs font-semibold uppercase tracking-widest">All Pieces</span>
      <span class="px-4 py-2 rounded-full bg-white border border-[#031635]/15 text-[#031635] text-xs font-semibold uppercase tracking-widest">Outerwear</span>
      <span class="px-4 py-2 rounded-full bg-white border border-[#031635]/15 text-[#031635] text-xs font-semibold uppercase tracking-widest">Accessories</span>
    </div>
  </header>

  <div class="grid grid-cols-1 md:grid-cols-12 gap-8">
    {% for product in collection.products %}
      <article class="md:col-span-6 lg:col-span-4 glass-panel rounded-3xl overflow-hidden hover-lift group flex flex-col">
        <a href="{{ product.url }}" class="aspect-square relative bg-white block overflow-hidden">
          <img src="{{ product.featured_image | img_url: '600x600', crop: 'center' }}" alt="{{ product.title }}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
        </a>
        <div class="p-6 flex-grow flex flex-col justify-between">
          <a href="{{ product.url }}">
            <span class="text-[10px] uppercase tracking-widest text-[#70585b] font-semibold">{{ product.type | default: 'Spatial Edition' }}</span>
            <h3 class="font-headline-md text-2xl font-bold text-[#031635] mt-1">{{ product.title }}</h3>
          </a>
          <div class="flex justify-between items-center mt-6 pt-4 border-t border-[#031635]/10">
            <span class="text-lg font-bold text-[#031635]">{{ product.price | money }}</span>
            <form action="/cart/add" method="post">
              <input type="hidden" name="id" value="{{ product.variants.first.id }}" />
              <button type="submit" class="bg-[#031635] text-white px-4 py-2 rounded-lg text-xs font-semibold uppercase tracking-wider btn-hover-lift">
                Add to Bag
              </button>
            </form>
          </div>
        </div>
      </article>
