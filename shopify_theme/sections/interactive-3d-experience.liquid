<div class="max-w-[1280px] w-full mx-auto px-6 md:px-16 py-12">
  <div class="text-center mb-8">
    <span class="text-xs font-semibold uppercase tracking-widest text-[#70585b] block mb-1">Interactive Spatial Canvas</span>
    <h1 class="font-headline-md text-3xl md:text-5xl font-bold text-[#031635]">{{ section.settings.heading }}</h1>
  </div>

  <div class="glass-panel rounded-3xl h-[620px] w-full relative overflow-hidden soft-shadow border border-[#031635]/10 flex flex-col justify-between p-8">
    <div class="flex justify-between items-center z-10">
      <div class="flex items-center gap-2">
        <span class="w-2.5 h-2.5 rounded-full bg-[#70585b] animate-pulse"></span>
        <span class="font-mono text-xs uppercase tracking-widest text-[#031635]">LIVE WEBGL + THREE.JS CANVAS</span>
      </div>
    </div>

    <!-- Full-screen 3D Viewer -->
    <div data-threejs="spatial-artifact" class="absolute inset-0 w-full h-full cursor-grab active:cursor-grabbing"></div>

    <div class="z-10 flex flex-col sm:flex-row justify-between items-end gap-4">
      <div class="bg-[#fbf8fc]/90 backdrop-blur-md rounded-2xl p-6 border border-[#031635]/10 max-w-sm">
        <span class="text-[10px] font-semibold text-[#70585b] uppercase tracking-widest">Interactive Material</span>
        <h3 class="font-headline-md text-xl font-bold text-[#031635] mt-1">Sculptural Icosahedron Form</h3>
        <p class="text-xs text-[#44474e] mt-1">
          Click &amp; drag anywhere inside the viewport to inspect light reflection across the Soft Pink (#FADADD) memory alloy.
        </p>
      </div>

      <a href="/products/aurum-wave" class="bg-[#031635] text-white text-xs font-semibold uppercase tracking-wider px-8 py-4 rounded-xl btn-hover-lift inline-flex items-center gap-2 shadow-lg">
        Examine Aurum &amp; Onda <span class="material-symbols-outlined text-sm">arrow_forward</span>
      </a>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "3D Interactive Studio",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Spatial Form Consultation"
    }
  ],
  "presets": [
    {
      "name": "3D Interactive Studio"
    }
  ]
}
{% endschema %}
