<nav class="fixed top-0 w-full z-50 bg-[#fbf8fc]/80 backdrop-blur-xl border-b border-[#031635]/10 shadow-sm transition-all duration-300">
  <div class="flex justify-between items-center max-w-[1280px] mx-auto px-6 md:px-16 py-4">
    <div class="flex items-center">
      <button id="drawer-toggle" class="text-[#031635] hover:opacity-80 transition-opacity duration-300 scale-95 active:scale-90 mr-4" aria-label="Open Menu">
        <span class="material-symbols-outlined">menu</span>
      </button>
      <a href="{{ routes.root_url }}" class="font-headline-md text-2xl md:text-3xl font-bold tracking-tight text-[#031635]">{{ shop.name | default: 'Flow Wear' }}</a>
    </div>

    <div class="hidden md:flex space-x-8">
      {% for link in linklists[section.settings.menu].links %}
        <a href="{{ link.url }}" class="text-sm font-semibold tracking-wider text-[#44474e] hover:text-[#031635] transition-colors">{{ link.title }}</a>
      {% else %}
        <a href="/" class="text-sm font-semibold tracking-wider text-[#031635]">Home</a>
        <a href="/collections/all" class="text-sm font-semibold tracking-wider text-[#44474e] hover:text-[#031635]">Collections</a>
        <a href="/pages/lookbook" class="text-sm font-semibold tracking-wider text-[#44474e] hover:text-[#031635]">Lookbook</a>
        <a href="/pages/studio" class="text-sm font-semibold tracking-wider text-[#44474e] hover:text-[#031635]">3D Studio</a>
      {% endfor %}
    </div>

    <div class="flex space-x-4 items-center">
      <button class="cart-toggle-btn relative text-[#031635] hover:opacity-80 transition-opacity duration-300 scale-95 active:scale-90" aria-label="Shopping Bag">
        <span class="material-symbols-outlined">shopping_bag</span>
        <span class="cart-count-badge absolute -top-1.5 -right-1.5 bg-[#031635] text-white text-[10px] font-bold w-4 h-4 rounded-full flex items-center justify-center">{{ cart.item_count }}</span>
      </button>
      {% if shop.customer_accounts_enabled %}
        <a href="{{ routes.account_url }}" class="text-[#031635] hover:opacity-80 transition-opacity duration-300 scale-95 active:scale-90" aria-label="Account">
          <span class="material-symbols-outlined">person</span>
        </a>
      {% endif %}
    </div>
  </div>
</nav>

{% schema %}
{
  "name": "Header Navigation",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Primary Navigation Menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
