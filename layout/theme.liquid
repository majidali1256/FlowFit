<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{{ page_title }} | {{ shop.name }}</title>
  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}

  {{ content_for_header }}

  <!-- Fonts & Material Symbols -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,600&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=block" rel="stylesheet">

  <!-- Tailwind CSS CDN -->
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          colors: {
            primary: '{{ settings.color_primary | default: "#031635" }}',
            secondary: '{{ settings.color_secondary | default: "#70585b" }}',
            background: '{{ settings.color_background | default: "#fbf8fc" }}',
            surface: '{{ settings.color_background | default: "#fbf8fc" }}'
          },
          fontFamily: {
            'headline-md': ['Playfair Display', 'serif'],
            'body-md': ['Inter', 'sans-serif']
          }
        }
      }
    };
  </script>

  <!-- Flow Wear Theme Styles -->
  {{ 'theme.css' | asset_url | stylesheet_tag }}

  <!-- Three.js CDN -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
</head>
<body class="bg-background text-[#1b1b1e] antialiased relative min-h-screen">

  {% if settings.enable_webgl_shader %}
    <canvas id="global-shader-canvas" class="fixed inset-0 z-[-1] pointer-events-none opacity-45"></canvas>
  {% endif %}

  {% section 'header' %}

  <main role="main" id="MainContent" class="pt-24 pb-20">
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}

  <!-- Slide-Out Cart Drawer -->
  <aside id="cart-drawer" class="fixed inset-0 z-[110] pointer-events-none opacity-0 transition-opacity duration-300">
    <div id="cart-overlay" class="absolute inset-0 bg-[#031635]/25 backdrop-blur-sm"></div>
    <div id="cart-drawer-content" class="absolute top-0 right-0 h-full w-full max-w-md glass-panel shadow-2xl transform translate-x-full transition-transform duration-500 ease-out flex flex-col bg-[#fbf8fc]">
      <div class="p-6 border-b border-[#031635]/10 flex justify-between items-center">
        <div class="flex items-center gap-2">
          <span class="material-symbols-outlined text-[#031635]">shopping_bag</span>
          <span class="font-headline-md text-xl font-bold text-[#031635]">Shopping Bag</span>
        </div>
        <button id="cart-close" class="text-[#031635] hover:opacity-60 transition-opacity">
          <span class="material-symbols-outlined">close</span>
        </button>
      </div>
      <div id="cart-items-container" class="flex-1 overflow-y-auto p-6 space-y-4"></div>
      <div class="p-6 border-t border-[#031635]/10 bg-white/80 space-y-4">
        <div class="flex justify-between items-center">
          <span class="text-sm text-[#44474e]">Subtotal</span>
          <span id="cart-subtotal-price" class="font-headline-md text-xl font-bold text-[#031635]">$0.00</span>
        </div>
        <a href="/checkout" class="w-full bg-[#031635] text-white font-semibold text-sm py-4 rounded-lg btn-hover-lift uppercase tracking-widest text-center block">
          Proceed to Checkout
        </a>
      </div>
    </div>
  </aside>

  {{ 'theme.js' | asset_url | script_tag }}
</body>
</html>
